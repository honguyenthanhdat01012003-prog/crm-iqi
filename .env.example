# Server port
PORT=4000

# CORS allowed origins (comma-separated, leave empty to allow all origins)
# Example for web + Capacitor:
# ALLOWED_ORIGINS=https://crm-iqi.id.vn,https://localhost,capacitor://localhost
ALLOWED_ORIGINS=

# Node environment
NODE_ENV=production

# ========== DATABASE ==========
# Chế độ mặc định: SQLite local (file server/data/crm.db)
# Nếu muốn dùng Turso cloud, bỏ comment 2 dòng dưới:
# TURSO_URL=libsql://db-xxxx.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...
#
# Nếu không đặt TURSO_URL, app tự động dùng SQLite local trên VPS (nhanh hơn nhiều)

# ========== AUTO-SYNC ==========
# Tự động sync Google Sheets mỗi X millisecond (mặc định: 30000 = 30 giây)
# SYNC_INTERVAL_MS=30000

# ========== PERPLEXITY AI ==========
# API key cho Perplexity Sonar (phân tích thị trường BĐS)
# PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx
